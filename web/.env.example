# Pathways PWA environment template
# Copy to .env.local for local dev. Vercel reads from the project's
# environment variable settings instead.

# Backend URL. Local dev: http://localhost:7860 (FastAPI default).
# Production: https://prathik10-pathways.hf.space
VITE_API_URL=http://localhost:7860

# Optional default language for the manifest + first paint.
# The client also reads navigator.language + the server-detected language.
VITE_DEFAULT_LANGUAGE=en
