# Pathways — local development env template
# Copy to .env. The demo flow runs without any of these set.

# ---- Anthropic ---------------------------------------------------------------
# Required for live model calls. Not required to inspect the .claude/ config.
ANTHROPIC_API_KEY=

# ---- Pinecone (production NICCC corpus) --------------------------------------
# In demo mode (PATHWAYS_DEPLOY_MODE=demo), the pathways-corpus MCP server uses
# the seeded JSON corpus in mcp_servers/pathways_corpus/corpus.json and these
# variables are ignored.
PINECONE_API_KEY=
PINECONE_INDEX=pathways-niccc-tx

# ---- Twilio (SMS ingress) ----------------------------------------------------
# Sandbox credentials are fine for demo. Production needs a verified Twilio
# subaccount and a TX-friendly long-code or short-code.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15555555555

# ---- PostgreSQL (caseload-summarizer sub-agent) ------------------------------
# Read-only DSN pointing at views, not tables. Pathways enforces this at the
# role level in production; the MCP server only ever opens this DSN.
PATHWAYS_PG_RO_DSN=postgresql://pathways_ro:CHANGE_ME@localhost:5432/pathways

# ---- Pathways runtime --------------------------------------------------------
PATHWAYS_STATE=TX
PATHWAYS_DEPLOY_MODE=demo
PATHWAYS_CONFIDENCE_FLOOR=0.62
PATHWAYS_LOG_LEVEL=INFO

# ---- Observability (optional) ------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pathways-dev
OTEL_EXPORTER_OTLP_ENDPOINT=
